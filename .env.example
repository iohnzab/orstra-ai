# ─── Required ──────────────────────────────────────────────────────────────────

# JWT signing secret
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Fernet encryption key for connector credentials
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# PostgreSQL connection string
DATABASE_URL=postgresql://orstra:orstra_password@localhost:5432/orstra

# ─── AI ────────────────────────────────────────────────────────────────────────
# Users can also add their own key via the Settings page in the UI

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219

# ─── Optional integrations ─────────────────────────────────────────────────────

# Google Custom Search (for search_web tool)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Base URL for webhook links shown in the UI
API_BASE_URL=http://localhost:8000

# ─── Frontend (put in frontend/.env.local) ─────────────────────────────────────
VITE_API_URL=http://localhost:8000
